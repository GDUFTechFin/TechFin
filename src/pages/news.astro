<script>
    // 轮播图功能
    let slideIndex = 1;
    showSlides(slideIndex);

    function plusSlides(n) {
        showSlides((slideIndex += n));
    }

    function currentSlide(n) {
        showSlides((slideIndex = n));
    }

    function showSlides(n) {
        const slides = document.querySelectorAll(".slide");
        const dots = document.querySelectorAll(".dot");

        if (n > slides.length) {
            slideIndex = 1;
        }
        if (n < 1) {
            slideIndex = slides.length;
        }

        slides.forEach((slide) => {
            slide.style.display = "none";
        });

        dots.forEach((dot) => {
            dot.classList.remove("active");
        });

        slides[slideIndex - 1].style.display = "block";
        dots[slideIndex - 1].classList.add("active");
    }

    // 自动轮播
    setInterval(() => {
        plusSlides(1);
    }, 5000); // 每5秒切换一次

    // 添加事件监听器
    document.addEventListener("DOMContentLoaded", function () {
        const prevBtn = document.getElementById("prevBtn");
        const nextBtn = document.getElementById("nextBtn");
        const dots = document.querySelectorAll(".dot");

        prevBtn.addEventListener("click", function () {
            plusSlides(-1);
        });

        nextBtn.addEventListener("click", function () {
            plusSlides(1);
        });

        dots.forEach((dot, index) => {
            dot.addEventListener("click", function () {
                currentSlide(index + 1);
            });
        });
    });

    // 客户端JavaScript实现分类和分页功能
    document.addEventListener("DOMContentLoaded", function () {
        const categoryButtons = document.querySelectorAll(".category-btn");
        const newsItems = document.querySelectorAll(".news-item");
        const paginationBtns = document.querySelectorAll(".pagination-btn");

        // 分页相关变量
        let currentPage = 1;
        const itemsPerPage = 4;
        let currentCategory = "全部";

        // 默认显示全部新闻的第一页
        updateNewsDisplay();

        // 为每个分类按钮添加点击事件
        categoryButtons.forEach((button) => {
            button.addEventListener("click", function () {
                // 移除所有按钮的active类
                categoryButtons.forEach((btn) =>
                    btn.classList.remove("active"),
                );

                // 为当前按钮添加active类
                this.classList.add("active");

                // 设置当前分类并重置到第一页
                currentCategory = this.getAttribute("data-category");
                currentPage = 1;

                // 更新新闻显示
                updateNewsDisplay();

                // 更新分页按钮
                updatePaginationButtons();
            });
        });

        // 为分页按钮添加点击事件
        paginationBtns.forEach((button) => {
            button.addEventListener("click", function () {
                const page = this.getAttribute("data-page");

                if (page === "prev" && currentPage > 1) {
                    currentPage--;
                } else if (page === "next" && hasNextPage()) {
                    currentPage++;
                } else if (!isNaN(page)) {
                    currentPage = parseInt(page);
                }

                updateNewsDisplay();
                updatePaginationButtons();
            });
        });

        function updateNewsDisplay() {
            // 获取当前分类的新闻
            const filteredItems = Array.from(newsItems).filter((item) => {
                const itemCategory = item.getAttribute("data-category");
                return (
                    currentCategory === "全部" ||
                    itemCategory === currentCategory
                );
            });

            // 计算当前页要显示的新闻
            const startIndex = (currentPage - 1) * itemsPerPage;
            const endIndex = startIndex + itemsPerPage;
            const itemsToShow = filteredItems.slice(startIndex, endIndex);

            // 隐藏所有新闻
            newsItems.forEach((item) => {
                item.style.display = "none";
            });

            // 显示当前页的新闻
            itemsToShow.forEach((item) => {
                item.style.display = "block";
            });
        }

        function updatePaginationButtons() {
            // 更新分页按钮的激活状态
            paginationBtns.forEach((btn) => {
                if (btn.classList.contains("page-btn")) {
                    const pageNum = parseInt(btn.getAttribute("data-page"));
                    if (pageNum === currentPage) {
                        btn.classList.add("active");
                    } else {
                        btn.classList.remove("active");
                    }
                }
            });

            // 禁用上一页/下一页按钮当没有更多页时
            const prevBtn = document.querySelector(".prev-btn");
            const nextBtn = document.querySelector(".next-btn");

            prevBtn.disabled = currentPage <= 1;
            nextBtn.disabled = !hasNextPage();
        }

        function hasNextPage() {
            const filteredItems = Array.from(newsItems).filter((item) => {
                const itemCategory = item.getAttribute("data-category");
                return (
                    currentCategory === "全部" ||
                    itemCategory === currentCategory
                );
            });

            const startIndex = (currentPage - 1) * itemsPerPage;
            const endIndex = startIndex + itemsPerPage;

            return endIndex < filteredItems.length;
        }

        // 添加活动分类过滤功能
        const portfolioBtns = document.querySelectorAll(".portfolio-btn");
        const portfolioItems = document.querySelectorAll(".portfolio-item");

        portfolioBtns.forEach((btn) => {
            btn.addEventListener("change", function () {
                const selectedValue = this.value;

                portfolioItems.forEach((item) => {
                    const itemCategories = JSON.parse(
                        item.getAttribute("data-groups"),
                    );

                    if (selectedValue === "all") {
                        item.style.display = "block";
                    } else {
                        // 检查当前项目是否包含所选类别
                        if (itemCategories.includes(selectedValue)) {
                            item.style.display = "block";
                        } else {
                            item.style.display = "none";
                        }
                    }
                });
            });
        });
    });
</script>
