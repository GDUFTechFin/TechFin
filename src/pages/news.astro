---

<Layout
    title="DigitalScoop - SEO & Digital Marketing Agency HTML Template | Contact"
>
    <!-- 页头 -->
    <Header />

    <!-- 加载动画 -->
    <Preloader />

    <!--====== 滚动到顶部按钮 ======-->
    <div id="scrollUp" title="Scroll To Top">
        <i class="fas fa-arrow-up"></i>
    </div>
    <!--====== Scroll To Top Area End ======-->

    <!-- 页面标题 -->
    <PageTitle
        title="新闻动态"
        parentPage="首页"
        parentUrl="/"
        currentPage="新闻动态"
    />

    <class class="main overflow-hidden">


        <!-- 空白 -->
        <div style="height: 15vh;"></div>


        <div class="row justify-content-center">
                    <div class="col-12 col-md-10 col-lg-7">
                        <!-- Section Heading -->
                        <div class="section-heading text-center">
                            <h2>新闻</h2>
                            <p class="d-none d-sm-block mt-4">新闻、政策发布与解读</p>
                            <p class="d-block d-sm-none mt-4"></p>
                        </div>
                    </div>
                </div>

        <div class="news-container">
            <div class="news-container-left">
                <!-- 快讯，新闻列表 -->
                <div class="news-container-left-list">
                    <h3>最新新闻</h3>
                    {
                        newsData.map((item) => (
                            <a
                                href={item.link}
                                class="sidebar-news-item"
                                key={item.id}
                            >
                                <span class="sidebar-news-title">
                                    {item.title}
                                </span>
                            </a>
                        ))
                    }
                </div>
            </div>
            <div class="news-container-right">
                <!-- 轮播图 -->
                <div class="news-container-right-slideshow">
                    <div class="slideshow-container">
                        {newsData.slice(0, 10).map((item, index) => (
                            <div class={`slide ${index === 0 ? 'active' : ''}`} key={item.id}>
                                <img src={item.image} alt={item.title} />
                                <div class="news-container-right-slideshow-text">
                                    <div class="news-container-right-slideshow-text-title">
                                        {item.title}
                                    </div>
                                    <div class="news-container-right-slideshow-text-content">
                                        {item.summary}
                                    </div>
                                </div>
                            </div>
                        ))}
                    </div>
                    <div class="slideshow-controls">
                        <button class="prev-btn" id="prevBtn">❮</button>
                        <button class="next-btn" id="nextBtn">❯</button>
                    </div>
                    <div class="slideshow-dots">
                        {newsData.slice(0, 10).map((_, index) => (
                            <span 
                                class={`dot ${index === 0 ? 'active' : ''}`} 
                                key={index}
                                data-index={index + 1}
                            ></span>
                        ))}
                    </div>
                </div>

                <!-- 新闻分类按钮 -->
                <div class="news-category-buttons">
                    <button class="category-btn active" data-category="全部"
                        >全部</button
                    >
                    <button class="category-btn" data-category="综合新闻"
                        >综合新闻</button
                    >
                    <button class="category-btn" data-category="政策发布与解读"
                        >政策发布与解读</button
                    >
                </div>

                <!-- 新闻列表 -->
                <div class="news-list-container">
                    {
                        newsData.map((item) => (
                            <div
                                class={`news-item ${item.category.replace(" ", "-")}`}
                                key={item.id}
                                data-category={item.category}
                            >
                                <a class="news-item-content" href={item.link}>
                                    <img
                                        src={item.image}
                                        alt={item.title}
                                        class="news-item-image"
                                    />
                                    <div class="news-item-text">
                                        <h3>{item.title}</h3>
                                        <p>{item.summary}</p>
                                        <span class="news-date">
                                            {item.date}
                                        </span>
                                    </div>
                                </a>
                            </div>
                        ))
                    }
                </div>

                <!-- 分页按钮 -->
                <div class="pagination-container">
                    <button class="pagination-btn prev-btn" data-page="prev"
                        >上一页</button
                    >
                    <button class="pagination-btn page-btn active" data-page="1"
                        >1</button
                    >
                    <button class="pagination-btn page-btn" data-page="2"
                        >2</button
                    >
                    <button class="pagination-btn page-btn" data-page="3"
                        >3</button
                    >
                    <button class="pagination-btn next-btn" data-page="next"
                        >下一页</button
                    >
                </div>
            </div>
        </div>

        <!-- ***** 活动开始***** -->
        <section id="portfolio" class="portfolio-area overflow-hidden ptb_100">
            <div class="container">
                <div class="row justify-content-center">
                    <div class="col-12 col-md-10 col-lg-7">
                        <!-- Section Heading -->
                        <div class="section-heading text-center">
                            <h2>活动</h2>
                            <p class="d-none d-sm-block mt-4">活动通知与精彩回顾</p>
                            <p class="d-block d-sm-none mt-4">活动信息</p>
                        </div>
                    </div>
                </div>
                <div class="row justify-content-center text-center">
                    <div class="col-12">
                        <!-- Portfolio Menu -->
                        <div
                            class="portfolio-menu btn-group btn-group-toggle flex-wrap justify-content-center text-center mb-4 mb-md-5"
                            data-toggle="buttons"
                        >
                            <label
                                class="btn active d-table text-uppercase p-2"
                            >
                                <input
                                    type="radio"
                                    value="all"
                                    checked
                                    class="portfolio-btn"
                                />
                                <span>全部</span>
                            </label>
                            <label class="btn d-table text-uppercase p-2">
                                <input
                                    type="radio"
                                    value="培训"
                                    class="portfolio-btn"
                                />
                                <span>培训</span>
                            </label>
                            <label class="btn d-table text-uppercase p-2">
                                <input
                                    type="radio"
                                    value="路演"
                                    class="portfolio-btn"
                                />
                                <span>路演</span>
                            </label>
                            <label class="btn d-table text-uppercase p-2">
                                <input
                                    type="radio"
                                    value="论坛"
                                    class="portfolio-btn"
                                />
