        top: -1px;
    }

    .shape-top svg {
        display: block;
        width: calc(122% + 1.3px);
        height: 134px;
        position: relative;
        left: 50%;
        transform: translateX(-50%);
    }
</style>

<script>
    // 轮播功能实现
    document.addEventListener("DOMContentLoaded", function () {
        const carousels = {
            policy: {
                items: document.querySelectorAll('.policy-carousel .news-item'),
                currentIndex: 0,
                total: document.querySelectorAll('.policy-carousel .news-item').length
            },
            county: {
                items: document.querySelectorAll('.county-carousel .news-item'),
                currentIndex: 0,
                total: document.querySelectorAll('.county-carousel .news-item').length
            },
            fintech: {
                items: document.querySelectorAll('.fintech-carousel .news-item'),
                currentIndex: 0,
                total: document.querySelectorAll('.fintech-carousel .news-item').length
            }
        };

        // 为每个轮播设置自动播放
        Object.keys(carousels).forEach(type => {
            setInterval(() => {
                showNextItem(type);
            }, 5000);
        });

        // 全局函数用于改变新闻
        window.changeNews = function(type, direction) {
            const carousel = carousels[type];
            const prevIndex = carousel.currentIndex;
            carousel.currentIndex = (carousel.currentIndex + direction + carousel.total) % carousel.total;
            
            // 添加淡出动画
            carousel.items[prevIndex].classList.add('fade-out');
            
            setTimeout(() => {
                // 隐藏所有项目
                carousel.items.forEach(item => {
                    item.classList.remove('d-block', 'd-none', 'fade-out', 'fade-in');
                    item.classList.add('d-none');
                });
                
                // 显示当前项目
                carousel.items[carousel.currentIndex].classList.remove('d-none');
                carousel.items[carousel.currentIndex].classList.add('d-block', 'fade-in');
                
                // 移除动画类
                setTimeout(() => {
                    carousel.items[carousel.currentIndex].classList.remove('fade-in');
                }, 300);
            }, 300);
        };

        // 显示下一项
        function showNextItem(type) {
            const carousel = carousels[type];
            const prevIndex = carousel.currentIndex;
            carousel.currentIndex = (carousel.currentIndex + 1) % carousel.total;
            
            // 添加淡出动画
            carousel.items[prevIndex].classList.add('fade-out');
            
            setTimeout(() => {
                // 隐藏所有项目
                carousel.items.forEach(item => {
                    item.classList.remove('d-block', 'd-none', 'fade-out', 'fade-in');
                    item.classList.add('d-none');
                });
                
                // 显示当前项目
                carousel.items[carousel.currentIndex].classList.remove('d-none');
                carousel.items[carousel.currentIndex].classList.add('d-block', 'fade-in');
                
                // 移除动画类
                setTimeout(() => {
                    carousel.items[carousel.currentIndex].classList.remove('fade-in');
                }, 300);
            }, 300);
        }
        
        // 初始化：为第一个项目添加显示类
        Object.keys(carousels).forEach(type => {
            const carousel = carousels[type];
            if (carousel.items.length > 0) {
                carousel.items[0].classList.add('d-block');
            }
        });
    });
</script>